{
  "name": "jm-desktop",
  "version": "2.1.1",
  "description": "A jm comic desktop app for windows and linux by vue + electron.",
  "author": {
    "name": "Par9uet",
    "email": "par9uet@qq.com"
  },
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder --publish always",
    "build:latest": "vue-tsc && vite build && electron-builder --publish never",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "postinstall": "electron-builder install-app-deps && simple-git-hooks"
  },
  "dependencies": {
    "@alova/adapter-xhr": "^2.3.1",
    "@trpc/client": "^11.13.4",
    "@trpc/server": "^11.13.4",
    "@vueuse/core": "^14.2.1",
    "@vueuse/router": "^14.2.1",
    "alova": "^3.5.1",
    "archiver": "^7.0.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "express": "^5.2.1",
    "http-proxy-middleware": "^3.0.5",
    "https-proxy-agent": "^8.0.0",
    "mitt": "^3.0.1",
    "p-limit": "^7.3.0",
    "pinia": "^3.0.4",
    "radash": "^12.1.1",
    "sanitize-filename": "^1.6.3",
    "scroll-into-view-if-needed": "^3.1.0",
    "skia-canvas": "^3.0.8",
    "superjson": "^2.2.6",
    "swiper": "^12.1.2",
    "trpc-electron-fork": "^1.0.2",
    "typeface-roboto": "^1.1.13",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3",
    "vuetify": "^4.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@mdi/font": "^7.4.47",
    "@types/archiver": "^7.0.0",
    "@types/cors": "^2.8.19",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "rolldown": "1.0.0-rc.9",
    "sass-embedded": "^1.98.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3",
    "unocss": "66.3.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^8.0.0",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vite-plugin-vue-devtools": "^8.1.0",
    "vue-tsc": "^3.2.6"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm vue-tsc && pnpm lint-staged"
  },
  "lint-staged": {
    "src/**": [
      "oxlint",
      "oxfmt"
    ],
    "electron/**": [
      "oxlint",
      "oxfmt"
    ]
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.32.1"
}
